let controller = require("support/controller.cosm")
let models = require("support/models.cosm")
let store = require("agent/store.cosm")

let AgentTurn = Data.model("AgentTurn", {
  conversation: models.Conversation,
  inbound: models.InboundMessage,
  reply: models.AgentReply,
  command: Data.optional(Data.string())
})

def identity()
  {
    name: "iapetus",
    mode: "single-turn",
    control: "cosm",
    session_prefix: "agent:",
    persistence: "file-backed-thread"
  }
end

def conversation_key(channel, thread)
  channel + ":" + thread
end

def session_name(key)
  identity().session_prefix + key
end

def conversation_for_inbound(inbound, transcript = false, context = false)
  let now = Time.isoNow()
  let key = conversation_key(inbound.channel, inbound.thread)
  let value = {
    key: key,
    channel: inbound.channel,
    thread: inbound.thread,
    messages: [],
    sessionName: session_name(key),
    sessionLength: 0,
    transcript: transcript,
    context: context,
    createdAt: now,
    updatedAt: now
  }
  models.Conversation.validate(value)
  value
end

def load_conversation(inbound, transcript = false, context = false)
  let key = conversation_key(inbound.channel, inbound.thread)
  let loaded = store.loadRecord(key)
  loaded == false ? conversation_for_inbound(inbound, transcript, context) : loaded.conversation
end

def save_conversation(conversation)
  store.saveConversation(conversation).conversation
end

def processed(inbound, event_key)
  store.processed(conversation_key(inbound.channel, inbound.thread), event_key)
end

def mark_processed(conversation, event_key)
  store.markProcessed(conversation, event_key)
end

def reset_conversation(inbound, transcript = false, context = false)
  let fresh = conversation_for_inbound(inbound, transcript, context)
  save_conversation(fresh)
end

def command_name(text)
  text == "help" || text == "/help" ? "help" : (text == "reset" || text == "/reset" ? "reset" : (text == "status" || text == "/status" ? "status" : false))
end

def from_command(conversation, inbound, command)
  if command == "reset" then
    let fresh = conversation_for_inbound(inbound, conversation.transcript, conversation.context)
    Session.named(fresh.sessionName).reset()
    let reply = controller.command_reply(fresh, command)
    let value = {
      conversation: fresh,
      inbound: inbound,
      reply: reply,
      command: command
    }
    AgentTurn.validate(value)
    value
  else
    let reply = controller.command_reply(conversation, command)
    let updated = controller.next_conversation(conversation, inbound, reply)
    let value = {
      conversation: updated,
      inbound: inbound,
      reply: reply,
      command: command
    }
    AgentTurn.validate(value)
    value
  end
end

def from_controller_turn(conversation, inbound)
  let outcome = Kernel.try(->() { controller.turn(conversation, inbound) })
  let turn = outcome.ok ? outcome.value : {
    conversation: controller.next_conversation(conversation, inbound, controller.fallback(conversation, inbound, outcome.error.message)),
    inbound: inbound,
    reply: controller.fallback(conversation, inbound, outcome.error.message)
  }
  let value = {
    conversation: turn.conversation,
    inbound: inbound,
    reply: turn.reply,
    command: false
  }
  AgentTurn.validate(value)
  value
end

def execute_turn(conversation, inbound)
  let command = command_name(inbound.text)
  command == false ? from_controller_turn(conversation, inbound) : from_command(conversation, inbound, command)
end

def execute_stored_turn(inbound, transcript = false, context = false)
  let conversation = load_conversation(inbound, transcript, context)
  let turn = execute_turn(conversation, inbound)
  let saved = save_conversation(turn.conversation)
  let value = {
    conversation: saved,
    inbound: turn.inbound,
    reply: turn.reply,
    command: turn.command
  }
  AgentTurn.validate(value)
  value
end

def status()
  identity()
end

def conversationKey(channel, thread)
  conversation_key(channel, thread)
end

def sessionName(key)
  session_name(key)
end

def conversationForInbound(inbound, transcript = false, context = false)
  conversation_for_inbound(inbound, transcript, context)
end

def loadConversation(inbound, transcript = false, context = false)
  load_conversation(inbound, transcript, context)
end

def saveConversation(conversation)
  save_conversation(conversation)
end

def markProcessed(conversation, eventKey)
  mark_processed(conversation, eventKey)
end

def resetConversation(inbound, transcript = false, context = false)
  reset_conversation(inbound, transcript, context)
end

def commandName(text)
  command_name(text)
end

def fromCommand(conversation, inbound, command)
  from_command(conversation, inbound, command)
end

def fromControllerTurn(conversation, inbound)
  from_controller_turn(conversation, inbound)
end

def executeTurn(conversation, inbound)
  execute_turn(conversation, inbound)
end

def executeStoredTurn(inbound, transcript = false, context = false)
  execute_stored_turn(inbound, transcript, context)
end
