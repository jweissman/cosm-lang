let models = require("support/models.cosm")
let config = require("agent/config.cosm")

let agent_thread_record = Data.model("agent_thread_record", {
  conversation: models.conversation,
  processed_events: Data.array(Data.string())
})

def storage_dir = config.slack_storage_dir();

def ready_probe_path = storage_dir() + "/.ready";

def record_path(key) = storage_dir() + "/" + Kernel.hmacSha256("cosm-agent-store", key) + ".json";

def record(conversation, processed_events = [])
  let value = { conversation: conversation, processed_events: processed_events }
  agent_thread_record.validate(value)
  value
end

def load_record(key)
  if Kernel.exists(record_path(key)) then
    let value = Kernel.parseJson(Kernel.readText(record_path(key)))
    agent_thread_record.validate(value)
    value
  else
    false
  end
end

def save_record(key, value)
  agent_thread_record.validate(value)
  Kernel.writeText(record_path(key), Kernel.json(value))
  value
end

def save_conversation(conversation)
  let key = conversation.key
  let loaded = load_record(key)
  let processed_events = loaded == false ? [] : loaded.processed_events
  save_record(key, record(conversation, processed_events))
end

def processed(key, event_key)
  let loaded = load_record(key)
  if loaded == false then
    false
  else
    loaded.processed_events.find(->(entry) { entry == event_key }) != false
  end
end

def next_processed_events(loaded, event_key)
  if loaded == false then
    [event_key]
  else
    if loaded.processed_events.find(->(entry) { entry == event_key }) != false then
      loaded.processed_events
    else
      loaded.processed_events.append(event_key)
    end
  end
end

def mark_processed(conversation, event_key)
  let loaded = load_record(conversation.key)
  save_record(conversation.key, record(conversation, next_processed_events(loaded, event_key)))
end

def writable()
  let outcome = Kernel.try(->() { Kernel.writeText(ready_probe_path(), Time.isoNow()) })
  outcome.ok
end
