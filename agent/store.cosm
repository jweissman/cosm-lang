require("support/models.cosm")
require("agent/config.cosm")

let AgentThreadRecord = Data.model("AgentThreadRecord", {
  conversation: models.Conversation,
  processedEvents: Data.array(Data.string())
})

def storageDir()
  config.slackStorageDir()
end

def readyProbePath()
  storageDir() + "/.ready"
end

def recordPath(key)
  storageDir() + "/" + Kernel.hmacSha256("cosm-agent-store", key) + ".json"
end

def record(conversation, processedEvents = [])
  let value = {
    conversation: conversation,
    processedEvents: processedEvents
  }
  AgentThreadRecord.validate(value)
  value
end

def loadRecord(key)
  if Kernel.exists(recordPath(key)) then
    let value = Kernel.parseJson(Kernel.readText(recordPath(key)))
    AgentThreadRecord.validate(value)
    value
  else
    false
  end
end

def saveRecord(key, value)
  AgentThreadRecord.validate(value)
  Kernel.writeText(recordPath(key), Kernel.json(value))
  value
end

def saveConversation(conversation)
  let key = conversation.key
  let loaded = loadRecord(key)
  let processed = if loaded == false then [] else loaded.processedEvents end
  let value = record(conversation, processed)
  saveRecord(key, value)
end

def processed(key, eventKey)
  let loaded = loadRecord(key)
  if loaded == false then
    false
  else
    loaded.processedEvents.find(->(entry) { entry == eventKey }) != false
  end
end

def nextProcessedEvents(loaded, eventKey)
  if loaded == false then
    [eventKey]
  else
    if loaded.processedEvents.find(->(entry) { entry == eventKey }) != false then
      loaded.processedEvents
    else
      loaded.processedEvents.append(eventKey)
    end
  end
end

def markProcessed(conversation, eventKey)
  let loaded = loadRecord(conversation.key)
  let processed = nextProcessedEvents(loaded, eventKey)
  let value = record(conversation, processed)
  saveRecord(conversation.key, value)
end

def writable()
  let outcome = Kernel.try(->() {
    Kernel.writeText(readyProbePath(), Time.isoNow())
  })
  outcome.ok
end
