require "support/models"
require "agent/config"
require "agent/runtime"
require "agent/store"
require "agent/slack_client"
require "cosm/ai"

def slack_config() = Agent::Config.slack_config_status();

def health_payload(path)
  {
    ok: true,
    path: path,
    pid: Process.pid(),
    platform: Process.platform(),
    arch: Process.arch()
  }
end

def ready_payload(path)
  let cfg = slack_config()
  let signing_secret_ok = cfg.signing_secret != false
  let bot_token_ok = cfg.bot_token != false
  let storage_ok = Agent::Store.writable()
  let ai_config = Cosm::AI.config()
  let ai_health = Cosm::AI.health()
  let ok = signing_secret_ok && bot_token_ok && storage_ok && ai_config.configured && ai_health.ok
  {
    ok: ok,
    path: path,
    slack: {
      signing_secret: signing_secret_ok,
      bot_token: bot_token_ok,
      app_id: cfg.app_id,
      client_id: cfg.client_id,
      client_secret: cfg.client_secret,
      api_url: cfg.api_url,
      storage_dir: cfg.storage_dir,
      storage_writable: storage_ok
    },
    ai: {
      configured: ai_config.configured,
      health: ai_health.ok
    },
    agent: Agent::Runtime.status()
  }
end

def status_payload(path)
  {
    ok: true,
    path: path,
    slack: {
      transport: "slack",
      dm_only: true,
      config: slack_config(),
      storage_writable: Agent::Store.writable()
    },
    ai: {
      config: Cosm::AI.config(),
      health: Cosm::AI.health()
    },
    agent: Agent::Runtime.status()
  }
end

def health(req)
  HttpResponse.json(health_payload(req.path), 200)
end

def ready(req)
  let payload = ready_payload(req.path)
  HttpResponse.json(payload, payload.ok ? 200 : 503)
end

def status(req)
  HttpResponse.json(status_payload(req.path), 200)
end

def events(req)
  let verification = verify_request(req)
  if verification.ok == false then
    puts("[slack] verification failed: " + verification.error)
    HttpResponse.json({ ok: false, error: verification.error }, verification.status)
  else
    let payload_result = Kernel.try(->() { Kernel.parseJson(req.bodyText()) })
    if payload_result.ok == false then
      puts("[slack] invalid json payload")
      HttpResponse.json({ ok: false, error: "Slack request body must be valid JSON" }, 400)
    else
      let payload = payload_result.value
      let challenge = url_verification(payload)
      if challenge != false then
        HttpResponse.json({ challenge: challenge }, 200)
      else
        let inbound = extract_inbound(payload)
        if inbound == false then
          puts("[slack] ignored non-dm or bot event")
          HttpResponse.json({ ok: true, ignored: true }, 200)
        else
          let event_key = event_key(payload, inbound)
          if Agent::Runtime.processed(inbound, event_key) then
            puts("[slack] deduped delivery " + event_key)
            HttpResponse.json({ ok: true, deduped: true }, 200)
          else
            handle_inbound(inbound, event_key)
          end
        end
      end
    end
  end
end

def handle_inbound(inbound, event_key)
  let turn = Agent::Runtime.execute_stored_turn(inbound)
  let posted = post_reply(turn.conversation, turn.reply.text)
  if posted.ok then
    Agent::Runtime.mark_processed(turn.conversation, event_key)
    HttpResponse.json({
      ok: true,
      replied: true,
      command: turn.command,
      session_name: turn.conversation.session_name
    }, 200)
  else
    let message = turn.command == false ? "[slack] outbound failure for thread " + inbound.thread + ": " + posted.error : "[slack] outbound failure for command " + turn.command + ": " + posted.error
    puts(message)
    HttpResponse.json({ ok: false, error: posted.error }, 502)
  end
end

def post_reply(conversation, text)
  Agent::SlackClient.post_message(conversation.channel, text, conversation.thread)
end

def verify_request(req)
  let signing_secret = Agent::Config.slack_signing_secret()
  if signing_secret == false then
    { ok: false, status: 500, error: "Slack signing secret is not configured" }
  else
    let timestamp = header(req, "x-slack-request-timestamp")
    let signature = header(req, "x-slack-signature")
    if timestamp == false || signature == false then
      { ok: false, status: 401, error: "Invalid Slack signature" }
    else
      let timestamp_seconds = Kernel.try(->() { timestamp.to_i() })
      if timestamp_seconds.ok == false then
        { ok: false, status: 401, error: "Invalid Slack signature" }
      else
        if (Time.now() - (timestamp_seconds.value * 1000)) > 300000 then
          { ok: false, status: 401, error: "Slack request timestamp is too old" }
        else
          let expected = "v0=" + Kernel.hmacSha256(signing_secret, "v0:" + timestamp + ":" + req.bodyText())
          expected == signature ? { ok: true, status: 200, error: false } : { ok: false, status: 401, error: "Invalid Slack signature" }
        end
      end
    end
  end
end

def url_verification(payload)
  let type_value = Kernel.try(->() { payload.type })
  if type_value.ok && type_value.value == "url_verification" then
    let challenge = Kernel.try(->() { payload.challenge })
    challenge.ok ? challenge.value : false
  else
    false
  end
end

def extract_inbound(payload)
  let payload_type = Kernel.try(->() { payload.type })
  if payload_type.ok == false || payload_type.value != "event_callback" then
    false
  else
    let event_result = Kernel.try(->() { payload.event })
    if event_result.ok == false then
      false
    else
      let event = event_result.value
      let type_value = Kernel.try(->() { event.type })
      let channel_type = Kernel.try(->() { event.channel_type })
      let channel = Kernel.try(->() { event.channel })
      let user = Kernel.try(->() { event.user })
      let text = Kernel.try(->() { event.text })
      let ts = Kernel.try(->() { event.ts })
      let bot_id = Kernel.try(->() { event.bot_id })
      let subtype = Kernel.try(->() { event.subtype })
      if type_value.ok == false || channel_type.ok == false || channel.ok == false || user.ok == false || text.ok == false || ts.ok == false then
        false
      else
        if type_value.value != "message" || channel_type.value != "im" || bot_id.ok || subtype.ok then
          false
        else
          let thread_value = Kernel.try(->() { event.thread_ts })
          let value = {
            channel: channel.value,
            thread: thread_value.ok ? thread_value.value : ts.value,
            user: user.value,
            text: text.value,
            ts: ts.value
          }
          Support::Models.inbound_message.validate(value)
          value
        end
      end
    end
  end
end

def event_key(payload, inbound)
  let top_level = Kernel.try(->() { payload.event_id })
  top_level.ok ? top_level.value : inbound.channel + ":" + inbound.thread + ":" + inbound.user + ":" + inbound.ts
end

def header(req, name)
  req.headers.has(name) ? req.headers.get(name) : false
end

def api_url()
  Agent::Config.slack_api_url()
end
