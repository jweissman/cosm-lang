require "agent/config"

def post_message(channel_id, text, thread_ts = false)
  let bot_token = Agent::Config.slack_bot_token()
  if bot_token == false then
    { ok: false, error: "Slack bot token is not configured" }
  else
    let payload = thread_ts == false ? { channel: channel_id, text: text } : { channel: channel_id, text: text, thread_ts: thread_ts }
    let request = Kernel.try(->() {
      http.request("POST", Agent::Config.slack_api_url(), {
        headers: Kernel.parseJson("{\"authorization\":\"Bearer " + bot_token + "\",\"content-type\":\"application/json; charset=utf-8\"}"),
        body: Kernel.json(payload)
      })
    })
    if request.ok == false then
      { ok: false, error: request.error.message }
    else
      let parsed = Kernel.try(->() { Kernel.parseJson(request.value.body) })
      if parsed.ok == false then
        { ok: false, error: "Slack API returned invalid JSON" }
      else
        if parsed.value.ok == true then
          let returned_channel = Kernel.try(->() { parsed.value.channel })
          let returned_ts = Kernel.try(->() { parsed.value.ts })
          {
            ok: true,
            status: request.value.status,
            channel_id: returned_channel.ok ? returned_channel.value : channel_id,
            ts: returned_ts.ok ? returned_ts.value : false,
            body: parsed.value
          }
        else
          let api_error = Kernel.try(->() { parsed.value.error })
          { ok: false, error: api_error.ok ? api_error.value : "unknown_error" }
        end
      end
    end
  end
end
