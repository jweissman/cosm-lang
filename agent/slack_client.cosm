let config = require("agent/config.cosm")

def post_message(target, text, thread = false)
  let bot_token = config.slack_bot_token()
  if bot_token == false then
    { ok: false, error: "Slack bot token is not configured" }
  else
    let payload = thread == false ? { channel: target, text: text } : { channel: target, text: text, thread_ts: thread }
    let request = Kernel.try(->() {
      http.request("POST", config.slack_api_url(), {
        headers: Kernel.parseJson("{\"authorization\":\"Bearer " + bot_token + "\",\"content-type\":\"application/json; charset=utf-8\"}"),
        body: Kernel.json(payload)
      })
    })
    if request.ok == false then
      { ok: false, error: request.error.message }
    else
      let parsed = Kernel.try(->() { Kernel.parseJson(request.value.body) })
      if parsed.ok == false then
        { ok: false, error: "Slack API returned invalid JSON" }
      else
        if parsed.value.ok == true then
          let channel_value = Kernel.try(->() { parsed.value.channel })
          let ts_value = Kernel.try(->() { parsed.value.ts })
          {
            ok: true,
            status: request.value.status,
            channel: channel_value.ok ? channel_value.value : target,
            ts: ts_value.ok ? ts_value.value : false,
            body: parsed.value
          }
        else
          let error_value = Kernel.try(->() { parsed.value.error })
          { ok: false, error: error_value.ok ? error_value.value : "unknown_error" }
        end
      end
    end
  end
end

def postMessage(target, text, thread = false)
  post_message(target, text, thread)
end
