require "agent/slack"
require "agent/runtime"

class AgentService
  def init(router)
    true
  end

  def handle(req)
    @router.handle(req)
  end

  class << self
    def build()
      let router = HttpRouter.new()

      router.use do |req, next|
        puts "[#{Time.isoNow()}] agent #{req.method} #{req.path}"
        next()
      end

      router.draw do
        get "/health" do |req|
          Agent::Slack.health(req)
        end

        get "/ready" do |req|
          Agent::Slack.ready(req)
        end

        get "/status" do |req|
          Agent::Slack.status(req)
        end

        get "/agent/status" do |req|
          HttpResponse.json({ ok: true, path: req.path, agent: Agent::Runtime.status() }, 200)
        end

        post "/slack/events" do |req|
          Agent::Slack.events(req)
        end
      end

      AgentService.new(router)
    end
  end
end
