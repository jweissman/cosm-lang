def env(primary, legacy = false)
  let current = Process.env(primary)
  current != false ? current : (legacy == false ? false : Process.env(legacy))
end

def slack_signing_secret()
  env("SLACK_SIGNING_SECRET", "COSM_SLACK_SIGNING_SECRET")
end

def slack_bot_token()
  env("SLACK_BOT_TOKEN", "COSM_SLACK_BOT_TOKEN")
end

def slack_app_id()
  env("SLACK_APP_ID")
end

def slack_client_id()
  env("SLACK_CLIENT_ID")
end

def slack_client_secret()
  env("SLACK_CLIENT_SECRET")
end

def slack_api_url()
  let configured = env("SLACK_API_URL", "COSM_SLACK_API_URL")
  configured == false ? "https://slack.com/api/chat.postMessage" : configured
end

def slack_storage_dir()
  let configured = env("SLACK_STORAGE_DIR", "COSM_SLACK_DIR")
  configured == false ? "var/slack/threads" : configured
end

def agent_port()
  let configured = env("AGENT_PORT", "COSM_AGENT_PORT")
  configured == false ? 12456 : configured.to_i()
end

def slack_config_status()
  {
    signing_secret: slack_signing_secret() != false,
    bot_token: slack_bot_token() != false,
    app_id: slack_app_id() != false,
    client_id: slack_client_id() != false,
    client_secret: slack_client_secret() != false,
    api_url: slack_api_url(),
    storage_dir: slack_storage_dir()
  }
end

def slackSigningSecret()
  slack_signing_secret()
end

def slackBotToken()
  slack_bot_token()
end

def slackAppId()
  slack_app_id()
end

def slackClientId()
  slack_client_id()
end

def slackClientSecret()
  slack_client_secret()
end

def slackApiUrl()
  slack_api_url()
end

def slackStorageDir()
  slack_storage_dir()
end

def agentPort()
  agent_port()
end

def slackConfigStatus()
  slack_config_status()
end
