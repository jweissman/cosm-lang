<div class="rounded-3xl border border-rose-500/30 bg-rose-500/10 p-6">
  <p class="text-xs font-semibold uppercase tracking-[0.3em] text-rose-300">Error</p>
  <p class="mt-4 text-sm font-semibold text-rose-100">#{message}</p>
  <pre class="mt-4 overflow-x-auto whitespace-pre-wrap break-words rounded-2xl bg-slate-950/70 p-4 font-mono text-sm text-rose-100">#{backtrace}</pre>
</div>
