<main class="mx-auto flex min-h-screen max-w-5xl flex-col gap-8 px-6 py-10">
  <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="text-sm uppercase tracking-[0.35em] text-emerald-300">Assistant Demo</p>
      <h1 class="mt-2 text-4xl font-black tracking-tight">Page-backed support conversation</h1>
      <p class="mt-3 max-w-3xl text-base text-slate-300">
        One page key, one shared support/controller core, and explicit AI config plus health surfaces instead of vague agent magic. This stays in the same tiny proving family as the CLI chat, notebook, and separate Slack agent service.
      </p>
    </div>
    <a class="text-sm text-slate-300 underline decoration-emerald-400 underline-offset-4" href="/">Back home</a>
  </div>

  <div class="grid gap-8 lg:grid-cols-[1.05fr,0.95fr]">
    <section class="rounded-[2rem] border border-slate-800 bg-slate-900/80 p-6 shadow-2xl shadow-slate-950/40">
      <form method="post" action="/assistant" class="space-y-4">
        <input type="hidden" name="key" value="<%= key %>" />
        <input type="hidden" name="transcript" value="<%= transcript %>" />
        <label class="block text-sm font-semibold uppercase tracking-[0.25em] text-slate-400">Message</label>
        <textarea name="message" class="min-h-[10rem] w-full rounded-2xl border border-slate-700 bg-slate-950 px-4 py-4 font-mono text-sm text-emerald-100 outline-none ring-0 placeholder:text-slate-600" spellcheck="false" placeholder="Ask Iapetus a support-style question..."></textarea>
        <div class="flex flex-wrap items-center gap-3">
          <button class="rounded-full bg-emerald-400 px-5 py-3 text-sm font-bold text-slate-950 transition hover:bg-emerald-300" type="submit">Send To Assistant</button>
          <a class="rounded-full border border-slate-700 px-5 py-3 text-sm font-bold text-slate-100 transition hover:border-cyan-400 hover:text-cyan-200" href="/assistant">Reset Page</a>
          <p class="text-sm text-slate-400">Conversation key <code class="text-emerald-300"><%= key %></code></p>
        </div>
      </form>
    </section>

    <section class="space-y-4">
      <div class="rounded-[2rem] border border-slate-800 bg-slate-900/80 p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-emerald-300">Transcript</p>
        <pre class="mt-4 whitespace-pre-wrap rounded-2xl border border-slate-800 bg-slate-950/70 p-4 text-sm text-slate-200"><%= transcript %></pre>
      </div>

      <div class="rounded-[2rem] border border-slate-800 bg-slate-900/80 p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">Latest Reply</p>
        <% if reply == false %>
          <p class="mt-4 text-sm text-slate-400">No reply yet. Submit a message to pressure the shared support/controller core through the page wedge.</p>
        <% else %>
          <p class="mt-4 text-base text-slate-100"><%= reply %></p>
        <% end %>
      </div>

      <div class="rounded-[2rem] border border-slate-800 bg-slate-900/80 p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-amber-300">AI Runtime</p>
        <dl class="mt-4 grid gap-3 text-sm text-slate-300">
          <div><dt class="font-semibold text-slate-100">Config</dt><dd><code class="text-emerald-300"><%= ai_config %></code></dd></div>
          <div><dt class="font-semibold text-slate-100">Health</dt><dd><code class="text-emerald-300"><%= ai_health %></code></dd></div>
          <div><dt class="font-semibold text-slate-100">Transcript</dt><dd><%= transcript_size %> character(s) on this page.</dd></div>
          <div><dt class="font-semibold text-slate-100">Streaming</dt><dd>The support core uses explicit stream events and now prefers real transport chunks when the local backend supports OpenAI-compatible streaming.</dd></div>
        </dl>
      </div>
    </section>
  </div>
</main>
