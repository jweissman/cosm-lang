require "lib/agent/slack_client"

def usage()
  """Usage: bun bin/cosm lib/agent/send_dm.cosm <channel_id> <text>

<channel_id> is a Slack conversation id, usually starting with D for a DM.
Example: bun bin/cosm lib/agent/send_dm.cosm D01234567 "hello from Cosm"
"""
end

def post_message(channel_id, text)
  Agent::SlackClient.post_message(channel_id, text)
end

def args_from(argv)
  let text = argv.reduce(false, ->(_acc, entry) { entry })
  let channel_id = argv.take(argv.length - 1).reduce(false, ->(_acc, entry) { entry })
  if channel_id == false || text == false || channel_id == text then
    false
  else
    { channel_id: channel_id, text: text }
  end
end

def run(argv = false)
  let args = argv == false ? Process.argv() : argv
  let parsed = args_from(args)
  if parsed == false then
    warn(usage())
    Process.exit(1)
  else
    let result = post_message(parsed.channel_id, parsed.text)
    if result.ok then
      let ts_text = result.ts == false ? "(none)" : result.ts
      puts("ok")
      puts("channel_id: " + result.channel_id)
      puts("ts: " + ts_text)
      result
    else
      warn("slack dm failed: " + result.error)
      Process.exit(1)
    end
  end
end
