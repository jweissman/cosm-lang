require "cosm/ai"
require "lib/support/models"
require "lib/support/prompts"
require "lib/support/replies"

def append_transcript(transcript, role, text) = transcript == "" ? role + ": " + text : transcript + "\n" + role + ": " + text;

def reply_for_transcript(transcript, latest_text)
  let reply = Cosm::AI.reply(Support::Prompts.reply_prompt_from_transcript(transcript, latest_text), Support::Models.agent_reply)
  Support::Models.agent_reply.validate(reply)
  reply
end

def reply_for_context(transcript, latest_text, context)
  let reply = Cosm::AI.reply(Support::Prompts.reply_prompt_from_context(transcript, latest_text, context), Support::Models.agent_reply)
  Support::Models.agent_reply.validate(reply)
  reply
end

def stream_reply_for_transcript(transcript, latest_text)
  let text = Cosm::AI.stream(Support::Prompts.stream_prompt_from_transcript(transcript, latest_text)) do |event|
    yield(event)
  end
  let reply = Support::Replies.text(text, "streamed")
  Support::Models.agent_reply.validate(reply)
  reply
end

def stream_reply_for_context(transcript, latest_text, context)
  let text = Cosm::AI.stream(Support::Prompts.stream_prompt_from_context(transcript, latest_text, context)) do |event|
    yield(event)
  end
  let reply = Support::Replies.text(text, "streamed")
  Support::Models.agent_reply.validate(reply)
  reply
end

def step_transcript(transcript, latest_text)
  let reply = reply_for_transcript(transcript, latest_text)
  let next_transcript = append_transcript(append_transcript(transcript, "user", latest_text), "assistant", reply.text)
  let step = { transcript: next_transcript, reply: reply }
  Support::Models.chat_step.validate(step)
  step
end

def stream_step_transcript(transcript, latest_text)
  let reply = stream_reply_for_transcript(transcript, latest_text)
  let next_transcript = append_transcript(append_transcript(transcript, "user", latest_text), "assistant", reply.text)
  let step = { transcript: next_transcript, reply: reply }
  Support::Models.chat_step.validate(step)
  step
end

def transcript_from_conversation(conversation) = conversation.messages.map(->(entry) { entry.role + ": " + entry.text }).join("\n");

def handle(conversation, inbound)
  Support::Models.conversation.validate(conversation)
  Support::Models.inbound_message.validate(inbound)
  step_transcript(transcript_from_conversation(conversation), inbound.text).reply
end

def fallback(conversation, inbound, error_message)
  Support::Models.conversation.validate(conversation)
  Support::Models.inbound_message.validate(inbound)
  Support::Replies.unavailable(error_message)
end

def example_conversation() = { key: "DDEMO:1710000000.000001", channel: "DDEMO", thread: "1710000000.000001", messages: [{ role: "user", user: "UDEMO", text: "How do I reset the notebook session?", ts: "1710000000.000001" }], session_name: "slack-demo", session_length: 1 };

def example_inbound() = { channel: "DDEMO", thread: "1710000000.000001", user: "UDEMO", text: "How do I reset the notebook session?", ts: "1710000000.000001" };

def preview() = Support::Prompts.reply_prompt_from_transcript(transcript_from_conversation(example_conversation()), example_inbound().text);
