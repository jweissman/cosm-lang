require "lib/support/agent"
require "lib/support/models"

def append_message(conversation, role, text)
  Support::Models.conversation.validate(conversation)
  let entry = { role: role, text: text }
  let messages = conversation.messages.append(entry)
  let value = {
    agent: conversation.agent,
    transport: conversation.transport,
    key: conversation.key,
    channel: conversation.channel,
    thread: conversation.thread,
    messages: messages,
    session_name: conversation.session_name,
    session_length: messages.length,
    transcript: conversation.transcript,
    context: conversation.context,
    created_at: conversation.created_at,
    updated_at: Time.isoNow()
  }
  Support::Models.conversation.validate(value)
  value
end

def append_user_message(conversation, inbound)
  Support::Models.conversation.validate(conversation)
  Support::Models.inbound_message.validate(inbound)
  let entry = { role: "user", user: inbound.user, text: inbound.text, ts: inbound.ts }
  let messages = conversation.messages.append(entry)
  let value = {
    agent: conversation.agent,
    transport: conversation.transport,
    key: conversation.key,
    channel: conversation.channel,
    thread: conversation.thread,
    messages: messages,
    session_name: conversation.session_name,
    session_length: messages.length,
    transcript: conversation.transcript,
    context: conversation.context,
    created_at: conversation.created_at,
    updated_at: Time.isoNow()
  }
  Support::Models.conversation.validate(value)
  value
end

def cli_conversation(messages)
  let now = Time.isoNow()
  let value = {
    agent: "iapetus",
    transport: "cli",
    key: "cli:iapetus",
    channel: "cli",
    thread: "cli",
    messages: messages,
    session_name: "iapetus-cli",
    session_length: messages.length,
    transcript: false,
    context: false,
    created_at: now,
    updated_at: now
  }
  Support::Models.conversation.validate(value)
  value
end

def page_conversation(key, transcript, context = false)
  let now = Time.isoNow()
  let value = {
    agent: "iapetus",
    transport: "web",
    key: key,
    channel: "web",
    thread: key,
    messages: [],
    session_name: "iapetus-page",
    session_length: 0,
    transcript: transcript,
    context: context,
    created_at: now,
    updated_at: now
  }
  Support::Models.conversation.validate(value)
  value
end

def cli_inbound(text)
  let value = { channel: "cli", thread: "cli", user: "you", text: text, ts: "cli" }
  Support::Models.inbound_message.validate(value)
  value
end

def page_inbound(key, text)
  let value = { channel: "web", thread: key, user: "visitor", text: text, ts: key }
  Support::Models.inbound_message.validate(value)
  value
end

def current_transcript(conversation) = conversation.transcript == false ? Support::Agent.transcript_from_conversation(conversation) : conversation.transcript;

def reply(conversation, inbound)
  Support::Models.conversation.validate(conversation)
  Support::Models.inbound_message.validate(inbound)
  conversation.context == false ? Support::Agent.reply_for_transcript(current_transcript(conversation), inbound.text) : Support::Agent.reply_for_context(current_transcript(conversation), inbound.text, conversation.context)
end

def stream_reply(conversation, inbound)
  Support::Models.conversation.validate(conversation)
  Support::Models.inbound_message.validate(inbound)
  if conversation.context == false then
    Support::Agent.stream_reply_for_transcript(current_transcript(conversation), inbound.text) do |event|
      yield(event)
    end
  else
    Support::Agent.stream_reply_for_context(current_transcript(conversation), inbound.text, conversation.context) do |event|
      yield(event)
    end
  end
end

def next_conversation(conversation, inbound, reply)
  if conversation.transcript == false then
    let with_user = append_user_message(conversation, inbound)
    append_message(with_user, "assistant", reply.text)
  else
    let next_transcript = Support::Agent.append_transcript(Support::Agent.append_transcript(current_transcript(conversation), "user", inbound.text), "assistant", reply.text)
    page_conversation(conversation.key, next_transcript, conversation.context)
  end
end

def display_transcript(conversation) = current_transcript(conversation);

def command_reply(conversation, command)
  Support::Models.conversation.validate(conversation)
  let thread_label = conversation.transport == "slack" ? "this DM thread" : "this conversation"
  let text = command == "help" ? "Iapetus is a persistent support assistant. Send a normal message to chat, `reset` to clear " + thread_label + ", or `status` to inspect the current memory." : (command == "reset" ? "Conversation memory cleared. The next message starts from a clean transcript and named session." : (command == "status" ? "This conversation is using `" + conversation.session_name + "` with " + conversation.messages.length.to_s() + " stored messages. Send `reset` to clear just " + thread_label + "." : "I can chat here and keep conversation-local memory. Send `help`, `status`, or `reset`."))
  let value = {
    should_reply: true,
    text: text,
    rationale: "meta",
    internal_summary: false,
    next_mode: "reply",
    degraded: false,
    failure_reason: false,
    tool_calls: false,
    tool_results: false
  }
  Support::Models.agent_reply.validate(value)
  value
end

def turn(conversation, inbound)
  let next_reply = reply(conversation, inbound)
  let value = { conversation: next_conversation(conversation, inbound, next_reply), inbound: inbound, plan: false, reply: next_reply, command: false, outcome: "reply" }
  Support::Models.controller_turn.validate(value)
  value
end

def stream_turn(conversation, inbound)
  let next_reply = stream_reply(conversation, inbound) do |event|
    yield(event)
  end
  let value = { conversation: next_conversation(conversation, inbound, next_reply), inbound: inbound, plan: false, reply: next_reply, command: false, outcome: "reply" }
  Support::Models.controller_turn.validate(value)
  value
end

def handle(conversation, inbound) = turn(conversation, inbound).reply;

def fallback(conversation, inbound, error_message) = Support::Agent.fallback(conversation, inbound, error_message);
