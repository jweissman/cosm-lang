<button class="notebook-example rounded-2xl border border-slate-800 bg-slate-900/80 p-4 text-left transition hover:border-cyan-400 hover:bg-slate-900" type="button" data-code="<%= code %>">
  <p class="text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300"><%= category %></p>
  <p class="mt-2 text-lg font-bold text-slate-100"><%= title %></p>
  <p class="mt-2 text-sm text-slate-300"><%= description %></p>
  <pre class="mt-3 overflow-x-auto whitespace-pre-wrap break-words rounded-xl bg-slate-950/70 p-3 font-mono text-xs text-cyan-100"><%= code %></pre>
</button>
