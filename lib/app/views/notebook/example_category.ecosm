<section class="space-y-3">
  <div class="flex items-end justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-amber-300"><%= title %></p>
      <p class="mt-2 text-sm text-slate-400"><%= description %></p>
    </div>
  </div>
  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3"><%= cards %></div>
</section>
