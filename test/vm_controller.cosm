let conversation = {
  key: "cli:iapetus",
  channel: "cli",
  thread: "cli",
  messages: [{ role: "user", text: "How do I reset the session?" }],
  sessionName: "iapetus-cli",
  sessionLength: 1
}

let inbound = {
  channel: "cli",
  thread: "cli",
  user: "you",
  text: "Use the Reset Session button.",
  ts: "cli"
}

let assistant = {
  role: "assistant",
  text: inbound.text
}

let next_messages = conversation.messages.append(assistant)
let next_conversation = {
  key: conversation.key,
  channel: conversation.channel,
  thread: conversation.thread,
  messages: next_messages,
  sessionName: conversation.sessionName,
  sessionLength: next_messages.length
}

if next_conversation.sessionLength == 2 then
  assistant.text
else
  "bad-state"
end
