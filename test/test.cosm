## Tiny Cosm-native test harness exercise

require("cosm/test");

expectEqual(Kernel.inspect(Kernel), "#<Kernel>");

def kernelExamples()
  test("math smoke", ->() { assert(1 + 1 == 2) });
  test("expectEqual smoke", ->() { expectEqual([1, 2], [1, 2]) });
  test("inspect smoke", ->() { assert(Kernel.inspect(Kernel) == "#<Kernel>") });
  test("explicit send smoke", ->() { assert(Kernel.send(1, :plus, 2) == 3) })
end;

def callableExamples()
  let id = ->(x) { x };
  test("function call smoke", ->() { assert(id.call(4) == 4) });
  test("method call smoke", ->() { assert(Kernel.method(:assert).call(true, "ok") == true) })
end;

class HarnessThing
  def init(value)
    assert(@value == value)
  end
end;

def objectExamples()
  test("class smoke", ->() { assert(HarnessThing.new(3).value == 3) });
  test("sad path", ->() { assert(false, "boom") })
end;

describe("kernel basics", kernelExamples);
describe("callables", callableExamples);
describe("objects", objectExamples);

"test harness complete"
