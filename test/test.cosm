## Tiny Cosm-native test harness exercise

require "cosm/spec.cosm"

Cosm::Spec.assert_equal(Kernel.inspect(Kernel), "#<Kernel>")

def kernel_examples()
  Cosm::Spec.it("math smoke", ->() { Cosm::Spec.assert(1 + 1 == 2) })
  Cosm::Spec.it("expectEqual smoke", ->() { Cosm::Spec.assert_equal([1, 2], [1, 2]) })
  Cosm::Spec.it("inspect smoke", ->() { Cosm::Spec.assert(Kernel.inspect(Kernel) == "#<Kernel>") })
  Cosm::Spec.it("explicit send smoke", ->() { Cosm::Spec.assert(Kernel.dispatch(1, :plus, 2) == 3) })
end

def callable_examples()
  id = ->(x) { x }
  Cosm::Spec.it("function call smoke", ->() { Cosm::Spec.assert(id.call(4) == 4) })
  Cosm::Spec.it("method call smoke", ->() { Cosm::Spec.assert(Kernel.method(:assert).call(true, "ok") == true) })
end

class HarnessThing
  def init(value)
    Cosm::Spec.assert(@value == value)
  end
end

def object_examples()
  Cosm::Spec.it("class smoke", ->() { Cosm::Spec.assert(HarnessThing.new(3).value == 3) })
  Cosm::Spec.it("sad path", ->() {
    error = Cosm::Spec.expect_raises(->() { Cosm::Spec.assert(false, "boom") }, "Assertion failed: boom")
    Cosm::Spec.assert_equal(error.message, "Assertion failed: boom")
  })
end

Cosm::Spec.suite("kernel basics", kernel_examples)
Cosm::Spec.suite("callables", callable_examples)
Cosm::Spec.suite("objects", object_examples)

Cosm::Spec.finish()
