## Tiny Cosm-native test harness exercise

require "cosm/spec.cosm"

assert_equal(Kernel.inspect(Kernel), "#<Kernel>")

def kernel_examples()
  it("math smoke", ->() { assert(1 + 1 == 2) })
  it("expectEqual smoke", ->() { assert_equal([1, 2], [1, 2]) })
  it("inspect smoke", ->() { assert(Kernel.inspect(Kernel) == "#<Kernel>") })
  it("explicit send smoke", ->() { assert(Kernel.dispatch(1, :plus, 2) == 3) })
end

def callable_examples()
  id = ->(x) { x }
  it("function call smoke", ->() { assert(id.call(4) == 4) })
  it("method call smoke", ->() { assert(Kernel.method(:assert).call(true, "ok") == true) })
end

class HarnessThing
  def init(value)
    assert(@value == value)
  end
end

def object_examples()
  it("class smoke", ->() { assert(HarnessThing.new(3).value == 3) })
  it("sad path", ->() {
    error = expect_raises(->() { assert(false, "boom") }, "Assertion failed: boom")
    assert_equal(error.message, "Assertion failed: boom")
  })
end

suite("kernel basics", kernel_examples)
suite("callables", callable_examples)
suite("objects", object_examples)
