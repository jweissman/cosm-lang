## Core self-test for current Cosm surface

# arithmetic, strings, and basic built-ins
assert(1 + 1 == 2, "math still works");
assert("co" + "sm" == "cosm", "string concatenation works");
assert("co".plus("sm") == "cosm", "string instances can send plus directly");
assert(3.send(:lt, 4) == true, "numeric comparison can flow through explicit message send");
assert(5.neg() == -5, "numeric unary behavior can flow through direct message send");
assert("co" == "co", "string equality still works through operator syntax");
assert(:ok == :ok, "symbol equality still works through operator syntax");
assert(true == true, "boolean equality still works through operator syntax");
assert([1, 2] == [1, 2], "array equality now also flows through eq message send");
assert({ answer: 42 } == { answer: 42 }, "hash equality now also flows through eq message send");
assert(true.and(false) == false, "boolean instances can send and directly");
assert(false.or(true) == true, "boolean instances can send or directly");
assert(true.not() == false, "boolean instances can send not directly");
assert("cosm".length == 4, "strings expose length as a property");
assert("items: " + [1, 2, 3].length == "items: 3", "arrays expose length as a property");
assert({ left: 1, right: 2 }.length == 2, "hashes expose length as a property");
assert("hello #{1 + 1}" == "hello 2", "strings can interpolate expressions");
assert(Kernel.assert(true) == true, "Kernel exposes assert as an ambient service");
assert true;
assert(Kernel.print("core print") == "core print", "Kernel exposes a basic print service");
assert(Kernel.puts("core self-test output") == "core self-test output", "Kernel exposes a basic puts service");
assert(Kernel.warn("core warning") == "core warning", "Kernel exposes a basic warn service");
puts 'core bare puts';
assert(cosm.Kernel.assert(true) == true, "cosm exposes Kernel reflectively");
assert(cosm.length >= 3, "namespaces expose a length property");
assert(cosm.has(:version) == true, "namespaces can answer has for reflective keys");
assert(cosm.keys().length >= 3, "namespaces can enumerate their reflective keys");
assert(cosm.get(:version) == "0.2.0", "namespaces can retrieve entries by symbol");
assert(classes.get(:Kernel).name == "Kernel", "the reflective class namespace can retrieve class entries");
assert(Kernel.class.name == "Kernel", "Kernel is now a real object with its own class");
assert(Process.class.name == "Process", "Process is now a real object with its own class");
assert(Time.class.name == "Time", "Time is now a real object with its own class");
assert(Random.class.name == "Random", "Random is now a real object with its own class");
assert(Kernel.inspect(Kernel) == "#<Kernel>", "Kernel can inspect runtime objects reflectively");
assert(Time.now() > 0, "Time exposes a simple time helper");
assert(Time.iso(0) == "1970-01-01T00:00:00.000Z", "Time can render timestamps as ISO-8601 strings");
assert(Time.isoNow().length >= 20, "Time exposes a convenient ISO-8601 helper for logging");
assert(Process.cwd().length > 0, "Process exposes the current working directory");
assert(Random.float() >= 0, "Random exposes a simple floating-point helper");
assert(Random.float() < 1, "Random float stays in the expected JS range");
assert(Random.int(5) >= 0, "Random exposes a simple integer helper");
assert(Random.int(5) < 5, "Random int stays below its upper bound");
assert(Kernel.send(1, :plus, 2) == 3, "Kernel can drive explicit message sends");
assert(Kernel.expectEqual([1, 2], [1, 2]) == true, "Kernel exposes a tiny equality expectation helper");
assert(classes.Kernel.send(:assert, true, "ok") == true, "class-object send can target introspected instance methods too");
assert(Kernel.method(:assert).class.name == "Method", "bound methods are first-class method objects");
assert(Kernel.method(:assert).name == "assert", "objects can introspect bound methods directly");
assert(Kernel.method(:assert).call(true) == true, "method objects can be invoked explicitly through call");
assert(classes.Kernel.method(:assert).name == "assert", "class objects can introspect instance methods directly");
assert(classes.Kernel.method(:assert).call(true, "ok") == true, "class-side method introspection returns callable Method objects");
assert(cosm.test.class.name == "Namespace", "cosm exposes a dedicated test namespace");
assert(cosm.test.has(:test) == true, "test namespace exposes a test entry point");
assert(cosm.test.has(:expectEqual) == true, "test namespace exposes a tiny equality helper");
require("cosm/test");
assert(test.class.name == "Function", "require can load the tiny test stdlib namespace");
assert(cosm.classes.String.name == "String", "cosm exposes the reflective class repository");
assert(http.class.name == "Http", "http is available as a reflective host-service object");
assert(cosm.http.class.name == "Http", "cosm exposes the http service reflectively");
assert(classes.class.name == "Namespace", "classes is a named reflective namespace object");
assert(cosm.class.name == "Namespace", "cosm is a named reflective namespace object");
assert(classes.Object.methods.send.name == "send", "Object reflects shared send through the runtime model");
assert(classes.Object.methods.method.name == "method", "Object reflects shared method lookup through the runtime model");
assert(classes.Class.methods.new.name == "new", "Class reflects constructor entry points through the runtime model");
assert(classes.Function.methods.call.name == "call", "Function reflects call through the runtime model");
assert(classes.Method.methods.call.name == "call", "Method reflects call through the runtime model");
assert(classes.Symbol.methods.eq.name == "eq", "Symbol reflects eq through the runtime model");
assert(classes.Symbol.classMethods.intern.name == "intern", "Symbol reflects intern on its metaclass");
assert(classes.Namespace.methods.keys.name == "keys", "Namespace reflects enumerable helpers through the runtime model");
assert(classes.Kernel.methods.assert.name == "assert", "Kernel reflects its ambient services through the runtime model");
assert(classes.Process.methods.cwd.name == "cwd", "Process reflects current-working-directory access through the runtime model");
assert(classes.Time.methods.now.name == "now", "Time reflects current time access through the runtime model");
assert(classes.Time.methods.isoNow.name == "isoNow", "Time reflects ISO-8601 rendering through the runtime model");
assert(classes.Random.methods.float.name == "float", "Random reflects floating-point sampling through the runtime model");
assert(classes.Http.methods.serve.name == "serve", "Http reflects Bun-native serving through the runtime model");
assert(classes.HttpRequest.methods.bodyText.name == "bodyText", "HttpRequest reflects request access through the runtime model");
assert(classes.HttpResponse.classMethods.text.name == "text", "HttpResponse reflects response construction through the runtime model");
assert(classes.HttpResponse.classMethods.json.name == "json", "HttpResponse reflects JSON response construction through the runtime model");
assert(classes.HttpServer.methods.stop.name == "stop", "HttpServer reflects lifecycle control through the runtime model");
assert(HttpResponse.ok("ok").status == 200, "HttpResponse.ok creates a basic response object");
assert(HttpResponse.text("made", 201).status == 201, "HttpResponse.text can override status");
assert(HttpResponse.json({ answer: 42 }, 202).headers.get("content-type") == "application/json", "HttpResponse.json installs a JSON content type");
assert(Kernel.inspect(HttpResponse.text("ok", 201)) == '#<HttpResponse 201 "ok">', "Kernel.inspect renders host response objects readably");
assert(:status.class.name == "Symbol", "symbol literals create first-class runtime values");
assert(:status == Symbol.intern("status"), "symbol literals reuse interned symbol values");
assert(1.send(:plus, 2) == 3, "values can send messages through explicit symbolic dispatch");
assert([1, 2].send(:eq, [1, 2]) == true, "structural equality can be driven through explicit eq send");
assert("symbol=#{:ok}" == "symbol=:ok", "symbols format cleanly in interpolation");
assert('#{1 + 1}' == '#{1 + 1}', "single-quoted strings do not interpolate");

# locals and data literals
let greeting = "hello";
let pair = { left: greeting, right: greeting + " cosm" };
assert(pair.left == "hello", "locals can feed hashes");
assert(pair.right == "hello cosm", "locals can be reused later");
assert("#{greeting} cosm" == "hello cosm", "interpolation can see locals");

# blocks and conditionals
assert(do let x = 1; x + 2 end == 3, "blocks return their last value");
let letShadow = do let greeting = "inner"; greeting end;
assert(letShadow == "inner", "blocks can create inner locals");
assert(greeting == "hello", "outer local survives block shadowing");
assert((if true then "yes" else "no" end) == "yes", "if picks the true branch");

# lambdas and defs
let prefix = "co";
let join = ->(rest) { prefix + rest };
assert(join("sm") == "cosm", "closures capture outer locals");
assert(join.call("sm") == "cosm", "functions can be invoked through call");
let twice = ->(value) { value + value };
assert(twice(21) == 42, "user-defined functions can be called");
def scoped() do
  let local = "hidden";
  local
end;
assert(scoped() == "hidden", "function body returns its last value");
def greet(name) do
  "hello " + name
end;
assert(greet("cosm") == "hello cosm", "def introduces named functions");
class ImplicitDispatch do
  def greet(name) do
    "hello " + name
  end
  def relay(name) do
    greet(name)
  end
end;
assert(ImplicitDispatch.new().relay("cosm") == "hello cosm", "unresolved bare calls can dispatch through self");

# classes, metaclasses, and reflective access
assert(1.plus(2) == 3, "number instances can send plus directly");
assert(Class.name == "Class", "Class is available as a reflective built-in");
assert(Number.class.name == "Number class", "built-in classes now have explicit metaclasses");
assert(Number.metaclass.name == "Number class", "class objects expose their metaclass directly");
assert(Number.metaclass.class.name == "Class", "metaclasses are themselves instances of Class");
assert(Number.class.superclass.name == "Object class", "built-in metaclasses follow the class inheritance chain");

# instance construction and instance-side methods
class Pair do
  def init(left, right) do
    true
  end
  def label() do
    "#{@left}:#{@right}"
  end
  def sum() do
    @left + @right
  end
  def classname() do
    self.class.name
  end
end;
let tuple = Pair.new(1, 2);
assert(Pair.name == "Pair", "class definitions bind a class value");
assert(classes.Pair.name == "Pair", "class definitions appear in the reflective classes view");
assert(Pair.slots.length == 2, "class definitions collect slots reflectively");
assert(Pair.methods.label.name == "label", "class defs collect methods reflectively");
assert(tuple.left == 1, "constructors assign slot values in order");
assert(tuple.right == 2, "constructors assign later slot values in order");
assert(tuple.label() == "1:2", "methods can use ivar shorthand for field provenance");
assert(tuple.sum() == 3, "ivars behave like direct instance-field reads");
assert(tuple.classname() == "Pair", "instances can send methods with self");
assert(Pair.new(1, 2) == Pair.new(1, 2), "instance equality now also flows through runtime eq");

# class-side methods and metaclass ownership
class Checked do
  def init(value) do
    assert(@value == value, "init bodies can observe assigned fields");
  end
end;
class Greeter do
  def self.label() do
    self.name + "!"
  end
  def self.kind() do
    self.class.name
  end
end;
class BaseLabel do
  def self.label() do
    "base"
  end
end;
class ChildLabel < BaseLabel do end;
assert(Checked.new(4).value == 4, "init signatures drive constructor arity and fields");
assert(Greeter.classMethods.label.name == "label", "class methods reflect separately from instance methods");
assert(Greeter.classMethod(:label).name == "label", "class objects can introspect bound class methods directly");
assert(Greeter.classMethod(:label).call() == "Greeter!", "bound class methods can be invoked through call");
assert(Greeter.label() == "Greeter!", "class objects can participate in method send when explicitly declared");
assert(Greeter.kind() == "Greeter class", "class-side self.class now reflects through the owning metaclass");
assert(ChildLabel.metaclass.superclass.name == "BaseLabel class", "user metaclasses inherit through the class hierarchy");
assert(ChildLabel.label() == "base", "class-side lookup follows the metaclass inheritance chain");

# ordinary object/hash access still works
assert({ greeting: "hello" }.greeting == "hello", "hash access works");
classes.String.name
