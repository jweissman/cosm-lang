let page = {
  key: "page-1",
  transcriptLines: ["user: hello", "assistant: hi"],
  reply: { text: "Use the Reset Session button." },
  ai: { ok: false, configured: false }
}

let preview = page.transcriptLines.take(1)
let base_transcript = if preview.length == 1 then
  preview.first()
else
  "bad-state"
end

let status_label = if page.ai.ok then
  "healthy"
else
  "offline"
end

let rendered_reply = Kernel.dispatch(page.reply.text, :plus, " [" + status_label + "]")
Kernel.dispatch(Kernel.dispatch(base_transcript, :plus, "\nassistant: "), :plus, rendered_reply)
