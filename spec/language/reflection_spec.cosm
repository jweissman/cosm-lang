assert(Object.new().methods() == [:eq, :method, :methods, :send, :inspect, :to_s], "ordinary receivers expose a symbol-list reflection surface")
assert(Object.new().method(:send).name == "send", "ordinary receivers can look up a concrete method object")
assert(Object.methods() == [:eq, :method, :methods, :send, :inspect, :to_s, :new, :classMethod, :include], "class receivers expose a callable symbol-list surface")
