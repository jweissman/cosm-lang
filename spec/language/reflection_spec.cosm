require "cosm/spec.cosm"

suite("Reflection", ->() {
  it("keeps receiver-side reflection compact", ->() {
    assert_equal(Object.new().methods(), [:eq, :method, :methods, :send, :inspect, :to_s])
    assert_equal(Object.new().method(:send).name, "send")
    assert_equal(Object.methods(), [:new, :classMethod, :include, :eq, :method, :methods, :send, :inspect, :to_s])
  })
})
