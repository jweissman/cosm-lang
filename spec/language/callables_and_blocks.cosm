require "cosm/spec.cosm"

suite("Blocks and callables", ->() {
  it("keeps block scope and conditionals explicit", ->() {
    assert(do let x = 1; x + 2 end == 3, "blocks return their last value")
    shadowed_greeting = do let greeting = "inner"; greeting end
    assert(shadowed_greeting == "inner", "blocks can create inner locals")
    greeting = "hello"
    assert(greeting == "hello", "outer local survives block shadowing")
    assert((if true then "yes" else "no" end) == "yes", "if picks the true branch")
  })

  it("supports lambdas, defs, and defaults", ->() {
    prefix = "co"
    join = ->(rest) { prefix + rest }
    assert(join("sm") == "cosm", "closures capture outer locals")
    assert(join.call("sm") == "cosm", "functions can be invoked through call")
    twice = ->(value) { value + value }
    assert(twice(21) == 42, "user-defined functions can be called")

    def scoped() do
      local = "hidden"
      local
    end
    assert(scoped() == "hidden", "function body returns its last value")

    def greet(name) do
      "hello " + name
    end
    assert(greet("cosm") == "hello cosm", "def introduces named functions")

    def default_greet(name = "cosm") do
      "hello " + name
    end
    assert(default_greet() == "hello cosm", "defs can use default arguments")
    assert(default_greet("runtime") == "hello runtime", "defs can override default arguments")

    default_join = ->(left, right = "sm") { left + right }
    assert(default_join("co") == "cosm", "lambdas can use default arguments")
    assert(default_join("co", "dex") == "codex", "lambdas can override default arguments")
  })

  it("supports implicit self dispatch and missing-method fallback", ->() {
    class ImplicitDispatch do
      def greet(name) do
        "hello " + name
      end
      def relay(name) do
        greet(name)
      end
    end
    assert(ImplicitDispatch.new().relay("cosm") == "hello cosm", "unresolved bare calls can dispatch through self")

    class MissingExample
      def does_not_understand(message, args)
        message.name + ":" + args.length
      end
      def render()
        wrapper("ok")
      end
    end
    assert(MissingExample.new().unknown(1, 2) == "unknown:2", "missing-method fallback can handle explicit sends")
    assert(MissingExample.new().render() == "wrapper:1", "missing-method fallback can support implicit self calls")
  })

  it("supports yield for the current trailing block", ->() {
    def with_block(value) do
      yield(value + 1)
    end
    assert(with_block(41) do |value| value end == 42, "yield can invoke the current trailing block with arguments")

    def nested_yield() do
      inner = ->() { yield("nested") }
      inner()
    end
    assert(nested_yield() do |label| label end == "nested", "nested calls preserve the current block context")

    error = expect_raises(->() { yield() }, "Block error: yield called without a current block")
    assert_equal(error.message, "Block error: yield called without a current block")

    def forward_block_value()
      yield(41)
    end
    assert((forward_block_value() do |value| value + 1 end) == 42, "yield can forward arguments into the current trailing block")
  })
})
