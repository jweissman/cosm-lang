require "cosm/spec.cosm"

suite("Kernel", ->() {
  it("ambient assertions and dispatch stay available", ->() {
    assert(Kernel.assert(true) == true)
    assert_equal(Kernel.dispatch(1, :plus, 2), 3)
  })
  it("explicit scalar helpers stay available", ->() {
    assert_equal("42".to_i(), 42)
    assert_equal("3.5".to_f(), 3.5)
    assert_equal(:status.to_s(), "status")
  })
  it("trace and validation helpers stay available", ->() {
    assert_equal(Kernel.trace("kernel spec", 41), 41)
    assert(Kernel.tryValidate(42, Schema.number()).ok == true)
  })
})

"kernel spec complete"
