require "cosm/spec.cosm"

Cosm::Spec.suite("Random", ->() {
  Cosm::Spec.it("numeric helpers stay in expected bounds", ->() {
    Cosm::Spec.assert(Random.float() >= 0)
    Cosm::Spec.assert(Random.float() < 1)
    Cosm::Spec.assert(Random.int(5) >= 0)
    Cosm::Spec.assert(Random.int(5) < 5)
  })
  Cosm::Spec.it("choice can select from arrays", ->() {
    Cosm::Spec.assert(Random.choice(["a", "b", "c"]).class.name == "String")
  })
})

"random spec complete"
