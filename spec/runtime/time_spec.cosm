require "cosm/spec.cosm"

Cosm::Spec.suite("Time", ->() {
  Cosm::Spec.it("iso helpers stay available", ->() {
    Cosm::Spec.assert(Time.iso(0) == "1970-01-01T00:00:00.000Z")
    Cosm::Spec.assert(Time.isoNow().length >= 20)
    Cosm::Spec.assert(Time.fromIso("1970-01-01T00:00:00.000Z") == 0)
  })
})

"time spec complete"
