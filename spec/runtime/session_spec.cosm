require("cosm/spec.cosm")

spec.suite("Session", ->() {
  spec.it("default session stays explicit", ->() {
    spec.assert_equal(Session.default().name, "default")
    spec.assert_equal(Kernel.session().name, "default")
  })
  spec.it("eval helpers stay structured", ->() {
    assert(Kernel.tryEval("1 + 2").ok == true)
    spec.assert_equal(Kernel.tryEval("1 + 2").inspect, "3")
  })
})

"session spec complete"
