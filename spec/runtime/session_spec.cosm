require "cosm/spec.cosm"

Cosm::Spec.suite("Session", ->() {
  Cosm::Spec.it("default session stays explicit", ->() {
    Cosm::Spec.assert_equal(Session.default().name, "default")
    Cosm::Spec.assert_equal(Kernel.session().name, "default")
  })
  Cosm::Spec.it("eval helpers stay structured", ->() {
    assert(Kernel.tryEval("1 + 2").ok == true)
    Cosm::Spec.assert_equal(Kernel.tryEval("1 + 2").inspect, "3")
  })
})

"session spec complete"
