require "cosm/spec.cosm"

suite("Session", ->() {
  it("default session stays explicit", ->() {
    assert_equal(Session.default().name, "default")
    assert_equal(Kernel.session().name, "default")
  })
  it("eval helpers stay structured", ->() {
    assert(Kernel.tryEval("1 + 2").ok == true)
    assert_equal(Kernel.tryEval("1 + 2").inspect, "3")
  })
})

"session spec complete"
