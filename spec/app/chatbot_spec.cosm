require "cosm/spec.cosm"
require "lib/support/chat"
require "lib/support/models"

suite("Support chatbot helpers", ->() {
  it("transcript appends stay stable", ->() {
    assert_equal(Support::Chat.append_transcript("", "user", "hello"), "user: hello")
    assert_equal(Support::Chat.append_transcript("user: hello", "assistant", "hi"), "user: hello\nassistant: hi")
  })
  it("step returns the structured chat-step model shape", ->() {
    let step = { transcript: "user: hello\nassistant: hi", reply: { should_reply: true, text: "hi", rationale: "mocked", tool_calls: false, tool_results: false } }
    assert(Support::Models.chat_step.validate(step) == true)
  })
  it("banner stays descriptive", ->() {
    assert(Support::Chat.banner().length > 20)
  })
})

"chatbot spec complete"
