require "cosm/test"

def suite(name, body) = Cosm::Test.describe(name, body);

def it(name, body) = Cosm::Test.test(name, body);

def assert_equal(actual, expected) = Cosm::Test.expectEqual(actual, expected);

def refute(value) = assert(value == false);

def expect_raises(body)
  let result = Kernel.try(body)
  assert(result.ok == false)
  result.error
end

def finish() = Cosm::Test.summary();
