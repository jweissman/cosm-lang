{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Cosm",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.cosm",
				"match": "\\b(def|do|else|end|if|let|then)\\b"
			},
			{
				"name": "storage.type.function.cosm",
				"match": "->"
			}]
		},
		"strings": {
			"name": "string.quoted.double.cosm",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.cosm",
					"match": "\\\\."
				}
			]
		}
	},
	"scopeName": "source.cosm"
}
