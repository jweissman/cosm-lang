{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Cosm",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#classes"
		},
		{
			"include": "#self"
		},
		{
			"include": "#defs"
		},
		{
			"include": "#ivars"
		},
		{
			"include": "#reflection"
		},
		{
			"include": "#constants"
		},
		{
			"include": "#strings"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.number-sign.cosm",
					"match": "#.*$"
				}
			]
		},
		"keywords": {
			"patterns": [{
				"name": "keyword.control.cosm",
				"match": "\\b(class|def|do|else|end|if|let|require|then|yield|super)\\b"
			},
			{
				"name": "storage.type.function.cosm",
				"match": "->"
			},
			{
				"name": "keyword.operator.assignment.cosm",
				"match": "="
			},
			{
				"name": "keyword.operator.namespace.cosm",
				"match": "::"
			},
			{
				"name": "keyword.operator.rest.cosm",
				"match": "\\*"
			}]
		},
		"self": {
			"patterns": [
				{
					"name": "variable.language.self.cosm",
					"match": "\\bself\\b"
				}
			]
		},
		"classes": {
			"patterns": [
				{
					"name": "entity.name.type.class.cosm",
					"match": "\\bclass\\s+([A-Za-z][A-Za-z0-9]*)\\b"
				},
				{
					"name": "entity.other.inherited-class.cosm",
					"match": "\\bclass\\s+[A-Za-z][A-Za-z0-9]*\\s+<\\s+([A-Za-z][A-Za-z0-9]*)\\b"
				},
				{
					"name": "support.class.cosm",
					"match": "\\b[A-Z][A-Za-z0-9]*\\b"
				}
			]
		},
		"defs": {
			"patterns": [
				{
					"name": "entity.name.function.cosm",
					"match": "\\bdef\\s+self\\.([A-Za-z][A-Za-z0-9]*)\\b"
				},
				{
					"name": "entity.name.function.cosm",
					"match": "\\bdef\\s+([A-Za-z][A-Za-z0-9]*)\\b"
				}
			]
		},
		"reflection": {
			"patterns": [
				{
					"name": "support.variable.property.reflective.cosm",
					"match": "\\.(class|metaclass|superclass|methods|classMethods|slots|name|length)\\b"
				}
			]
		},
		"ivars": {
			"patterns": [
				{
					"name": "variable.other.object.ivar.cosm",
					"match": "@[A-Za-z][A-Za-z0-9]*\\b"
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.numeric.cosm",
					"match": "\\b\\d+(?:\\.\\d+)?\\b"
				},
				{
					"name": "constant.language.boolean.cosm",
					"match": "\\b(true|false)\\b"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.cosm",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "meta.interpolation.cosm",
					"begin": "#\\{",
					"beginCaptures": {
						"0": {
							"name": "punctuation.section.interpolation.begin.cosm"
						}
					},
					"end": "\\}",
					"endCaptures": {
						"0": {
							"name": "punctuation.section.interpolation.end.cosm"
						}
					},
					"patterns": [
						{
							"include": "#comments"
						},
						{
							"include": "#keywords"
						},
						{
							"include": "#constants"
						}
					]
				},
				{
					"name": "constant.character.escape.cosm",
					"match": "\\\\."
				}
			]
		}
	},
	"scopeName": "source.cosm"
}
