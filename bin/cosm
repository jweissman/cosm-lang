#!/usr/bin/env bun

import { existsSync, readFileSync, watch, writeFileSync } from "node:fs";
import { join } from "node:path";
import Cosm from '../src/cosm';
import { Parser } from "../src/ast/parser";
import { Lowerer } from "../src/ast/lowerer";
import { ValueAdapter } from "../src/ValueAdapter";
import { RuntimeDispatch } from "../src/runtime/RuntimeDispatch";
import { CosmRaisedError } from "../src/runtime/CosmRaisedError";

const HISTORY_PATH = join(process.cwd(), ".cosm_history");

function loadHistory(): string[] {
  if (!existsSync(HISTORY_PATH)) {
    return [];
  }
  return readFileSync(HISTORY_PATH, "utf8")
    .split("\n")
    .map((line) => line.trimEnd())
    .filter((line) => line.length > 0);
}

function saveHistory(entries: string[]) {
  writeFileSync(HISTORY_PATH, `${entries.join("\n")}\n`, "utf8");
}

function usage(): string {
  return [
    "Usage:",
    "  cosm",
    "  cosm --version",
    "  cosm -e '<source>'",
    "  cosm test [file.cosm|spec/|test/]",
    "  cosm <file.cosm>",
    "  cosm <file.cosm> [args...]",
    "  cosm help",
    "  cosm --help",
    "  cosm <file.cosm> --test",
    "  cosm --test <file.cosm>",
    "  cosm <file.cosm> --watch",
    "  cosm <file.cosm> --trace-surface",
    "  cosm <file.cosm> --trace-core",
    "  cosm <file.cosm> --trace-ir",
    "  cosm <file.cosm> --trace-send",
    "  cosm <file.cosm> --vm   # experimental",
    "  cosm --watch <file.cosm>",
    "  cosm watch <file.cosm>",
  ].join("\n");
}

function formatCliError(error: unknown): string {
  if (error instanceof CosmRaisedError) {
    return error.cosmError.toDisplayString();
  }
  if (error instanceof Error) {
    return error.message;
  }
  return String(error);
}

type CliMode =
  | { kind: "version" }
  | { kind: "repl"; traceSurface: boolean; traceCore: boolean; traceIr: boolean; traceSend: boolean; vm: boolean }
  | { kind: "help"; traceSurface: boolean; traceCore: boolean; traceIr: boolean; traceSend: boolean; vm: boolean }
  | { kind: "eval"; source: string; traceSurface: boolean; traceCore: boolean; traceIr: boolean; traceSend: boolean; vm: boolean }
  | { kind: "run"; filePath: string; scriptArgs: string[]; traceSurface: boolean; traceCore: boolean; traceIr: boolean; traceSend: boolean; vm: boolean }
  | { kind: "test"; filePath?: string; scriptArgs: string[]; traceSurface: boolean; traceCore: boolean; traceIr: boolean; traceSend: boolean; vm: boolean }
  | { kind: "watch"; filePath: string; traceSurface: boolean; traceCore: boolean; traceIr: boolean; traceSend: boolean; vm: boolean };

type TraceSurfaceNode = {
  kind: string;
  value?: string;
  params?: string[];
  restParam?: string;
  target?: string;
  children?: TraceSurfaceNode[];
  left?: TraceSurfaceNode;
  right?: TraceSurfaceNode;
};

type TraceCoreNode = {
  kind: string;
  value?: string;
  params?: string[];
  restParam?: string;
  target?: string;
  children?: TraceCoreNode[];
  left?: TraceCoreNode;
  right?: TraceCoreNode;
};

function parseArgs(args: string[]): CliMode {
  let traceSurface = false;
  let traceCore = false;
  let traceIr = false;
  let traceSend = false;
  let vm = false;

  if (args.length === 0) {
    return { kind: "repl", traceSurface, traceCore, traceIr, traceSend, vm };
  }

  if (args.length === 1 && args[0] === "--version") {
    return { kind: "version" };
  }

  if (args.length === 1 && (args[0] === "help" || args[0] === "--help")) {
    return { kind: "help", traceSurface, traceCore, traceIr, traceSend, vm };
  }

  const modes = new Set<"test" | "watch">();
  let filePath: string | undefined;
  let evalSource: string | undefined;
  const scriptArgs: string[] = [];

  const takeFile = (value: string) => {
    if (filePath) {
      throw new Error(`unexpected extra argument '${value}'`);
    }
    filePath = value;
  };

  for (let index = 0; index < args.length; index += 1) {
    const arg = args[index];

    if (arg === "--help" || arg === "help") {
      if (args.length !== 1) {
        throw new Error("help cannot be combined with other arguments");
      }
      return { kind: "help", traceSurface, traceCore, traceIr, traceSend, vm };
    }

    if (arg === "--trace-surface") {
      traceSurface = true;
      continue;
    }

    if (arg === "--trace-core") {
      traceCore = true;
      continue;
    }

    if (arg === "--trace-ir") {
      traceIr = true;
      continue;
    }

    if (arg === "--trace-send") {
      traceSend = true;
      continue;
    }

    if (arg === "-e" || arg === "--eval") {
      const next = args[index + 1];
      if (next === undefined) {
        throw new Error(`${arg} expects a source string`);
      }
      if (evalSource !== undefined) {
        throw new Error(`${arg} cannot be given more than once`);
      }
      if (filePath) {
        throw new Error(`${arg} cannot be combined with a file path`);
      }
      evalSource = next;
      index += 1;
      continue;
    }

    if (arg === "--vm") {
      vm = true;
      continue;
    }

    if (arg === "--test" || arg === "test") {
      modes.add("test");
      const next = args[index + 1];
      if (next && !next.startsWith("-") && next !== "watch" && next !== "test" && !filePath) {
        filePath = next;
        index += 1;
      }
      continue;
    }

    if (arg === "--watch" || arg === "watch") {
      modes.add("watch");
      const next = args[index + 1];
      if (next && !next.startsWith("-") && next !== "watch" && next !== "test" && !filePath) {
        filePath = next;
        index += 1;
      }
      continue;
    }

    if (arg.startsWith("-")) {
      throw new Error(`unknown option '${arg}'`);
    }

    if (filePath) {
      scriptArgs.push(arg);
      continue;
    }

    takeFile(arg);
  }

  if (modes.has("test") && modes.has("watch")) {
    throw new Error("--watch and --test cannot be combined");
  }

  if (evalSource !== undefined) {
    if (modes.size > 0) {
      throw new Error("-e cannot be combined with --test or --watch");
    }
    return { kind: "eval", source: evalSource, traceSurface, traceCore, traceIr, traceSend, vm };
  }

  if (modes.has("test")) {
    return { kind: "test", filePath, scriptArgs, traceSurface, traceCore, traceIr, traceSend, vm };
  }

  if (modes.has("watch")) {
    if (!filePath) {
      throw new Error("--watch expects a file path");
    }
    return { kind: "watch", filePath, traceSurface, traceCore, traceIr, traceSend, vm };
  }

  if (!filePath) {
    return { kind: "repl", traceSurface, traceCore, traceIr, traceSend, vm };
  }

  return { kind: "run", filePath, scriptArgs, traceSurface, traceCore, traceIr, traceSend, vm };
}

function watchFileRunner(filePath: string, traces: { traceSurface: boolean; traceCore: boolean; traceIr: boolean; traceSend: boolean; vm: boolean }) {
  if (!existsSync(filePath)) {
    console.error(`Error: watch target does not exist: ${filePath}`);
    process.exit(1);
  }

  console.log(`[watch] watching ${filePath}`);

  let child: Bun.Subprocess | undefined;
  let restartTimer: ReturnType<typeof setTimeout> | undefined;
  let stopped = false;
  let restarting = false;

  const stopChild = async () => {
    if (!child) {
      return;
    }
    const runningChild = child;
    child = undefined;
    runningChild.kill("SIGTERM");
    try {
      await runningChild.exited;
    } catch {
      // Ignore shutdown races from child termination.
    }
  };

  const startChild = () => {
    const childArgs = ["bun", "bin/cosm", filePath];
    if (traces.traceSurface) childArgs.push("--trace-surface");
    if (traces.traceCore) childArgs.push("--trace-core");
    if (traces.traceIr) childArgs.push("--trace-ir");
    if (traces.traceSend) childArgs.push("--trace-send");
    if (traces.vm) childArgs.push("--vm");
    child = Bun.spawn(childArgs, {
      cwd: process.cwd(),
      stdin: "inherit",
      stdout: "inherit",
      stderr: "inherit",
    });
    child.exited.then((exitCode) => {
      if (stopped || child !== undefined && child.pid !== undefined && child.exitCode === null && restarting) {
        return;
      }
      if (!stopped && !restarting) {
        console.log(`[watch] child exited with code ${exitCode}; waiting for changes...`);
      }
    }).catch(() => {
      if (!stopped && !restarting) {
        console.log("[watch] child exited; waiting for changes...");
      }
    });
  };

  const restartChild = () => {
    if (stopped) {
      return;
    }
    if (restartTimer) {
      clearTimeout(restartTimer);
    }
    restartTimer = setTimeout(async () => {
      if (stopped) {
        return;
      }
      restarting = true;
      console.log(`[watch] restarting ${filePath}`);
      await stopChild();
      startChild();
      restarting = false;
    }, 60);
  };

  const close = async () => {
    if (stopped) {
      return;
    }
    stopped = true;
    watcher.close();
    if (restartTimer) {
      clearTimeout(restartTimer);
    }
    await stopChild();
  };

  const watcher = watch(filePath, (_eventType) => {
    restartChild();
  });

  process.on("SIGINT", async () => {
    await close();
    process.exit(0);
  });

  process.on("SIGTERM", async () => {
    await close();
    process.exit(0);
  });

  startChild();
}

function repl() {
  const readline = require('readline');
  const sessionEnv = Cosm.Interpreter.createEnv();
  const persistedHistory = loadHistory();
  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
    prompt: 'cosm> '
  });
  rl.history = [...persistedHistory].reverse();

  rl.prompt();

  rl.on('line', (line: string) => {
    const trimmed = line.trim();
    if (trimmed.length > 0) {
      const nextHistory = [...persistedHistory.filter((entry) => entry !== trimmed), trimmed];
      persistedHistory.splice(0, persistedHistory.length, ...nextHistory.slice(-500));
      saveHistory(persistedHistory);
    }
    try {
      const result = Cosm.Interpreter.evalInEnv(line, sessionEnv);
      console.log(Cosm.Interpreter.inspect(result, sessionEnv));
    } catch (e) {
      console.error("Error:", formatCliError(e));
    }
    rl.prompt();
  }).on('close', () => {
    console.log('Goodbye!');
    process.exit(0);
  });
}

function describeSurfaceAst(node: any): TraceSurfaceNode {
  const summary: TraceSurfaceNode = { kind: node.kind };
  if (node.value && node.value !== "") summary.value = node.value;
  if (node.params?.length) summary.params = node.params;
  if (node.restParam) summary.restParam = node.restParam;
  if (node.target) summary.target = node.target;
  if (node.left) summary.left = describeSurfaceAst(node.left);
  if (node.right) summary.right = describeSurfaceAst(node.right);
  if (node.children?.length) {
    summary.children = node.children.map((child: any) => describeSurfaceAst(child));
  }
  return summary;
}

function describeCoreAst(node: any): TraceCoreNode {
  const summary: TraceCoreNode = { kind: node.kind };
  if (node.value && node.value !== "") summary.value = node.value;
  if (node.params?.length) summary.params = node.params;
  if (node.restParam) summary.restParam = node.restParam;
  if (node.target) summary.target = node.target;
  if (node.left) summary.left = describeCoreAst(node.left);
  if (node.right) summary.right = describeCoreAst(node.right);
  if (node.children?.length) {
    summary.children = node.children.map((child: any) => describeCoreAst(child));
  }
  return summary;
}

function emitTraceFlags(source: string, traces: { traceSurface: boolean; traceCore: boolean; traceIr: boolean }): void {
  if (traces.traceSurface) {
    const surfaceAst = Parser.parseSurface(source);
    console.log("[trace-surface]");
    console.log(`# top-level forms: ${(surfaceAst.children ?? []).length}`);
    console.log(JSON.stringify(describeSurfaceAst(surfaceAst), null, 2));
  }
  if (traces.traceCore) {
    const coreAst = Lowerer.lower(Parser.parseSurface(source));
    console.log("[trace-core]");
    console.log(`# normalized statements: ${(coreAst.children ?? []).length}`);
    console.log(JSON.stringify(describeCoreAst(coreAst), null, 2));
  }
  if (traces.traceIr) {
    console.log("[trace-ir]");
    console.log(JSON.stringify(Cosm.Interpreter.ir(source), null, 2));
  }
}

function createTestEnv(): ReturnType<typeof Cosm.Interpreter.createEnv> {
  const env = Cosm.Interpreter.createEnv();
  Cosm.Interpreter.evalInEnv('require "cosm/spec.cosm"', env);
  return env;
}

function resolveTestTargets(filePath?: string): string[] {
  if (!filePath) {
    return ["spec/core.cosm", "spec/runtime/baseline.cosm"];
  }
  const normalized = filePath.replace(/\\/g, "/");
  if (normalized === "spec" || normalized === "spec/") {
    return ["spec/core.cosm", "spec/runtime/baseline.cosm"];
  }
  if (normalized === "test" || normalized === "test/") {
    return ["test/test.cosm"];
  }
  return [filePath];
}

function runSingleTestTarget(source: string, filePath: string, scriptArgs: string[], mode: { vm: boolean }): { passed: number; failed: number; total: number } {
  const originalArgv = [...process.argv];
  try {
    process.argv = [originalArgv[0] ?? "bun", originalArgv[1] ?? "bin/cosm", filePath, ...scriptArgs];
    Cosm.Interpreter.eval("Kernel.resetTests()");
    if (mode.vm) {
      Cosm.Interpreter.evalVm(source);
    } else {
      const env = createTestEnv();
      Cosm.Interpreter.evalInEnv(source, env);
    }
    return ValueAdapter.cosmToJS(Cosm.Interpreter.eval("Kernel.testSummary()"));
  } finally {
    process.argv = originalArgv;
  }
}

function runTestMode(filePath: string | undefined, scriptArgs: string[], mode: { vm: boolean; traceSurface: boolean; traceCore: boolean; traceIr: boolean }): never {
  const targets = resolveTestTargets(filePath);
  let failedTargets = 0;

  for (const [index, targetPath] of targets.entries()) {
    const source = readFileSync(targetPath, "utf8");
    if (targets.length > 1) {
      if (index > 0) {
        console.log("");
      }
      console.log(`==> ${targetPath}`);
    }
    emitTraceFlags(source, mode);
    const summary = runSingleTestTarget(source, targetPath, scriptArgs, mode);
    console.log(`${summary.passed} passed, ${summary.failed} failed, ${summary.total} total`);
    if (summary.failed > 0) {
      failedTargets += 1;
    }
  }

  if (targets.length > 1) {
    console.log("");
    console.log(`${targets.length - failedTargets} test bundles passed, ${failedTargets} failed`);
  }

  process.exit(failedTargets > 0 ? 1 : 0);
}

if (require.main === module) {
  let mode: CliMode;
  try {
    mode = parseArgs(process.argv.slice(2));
  } catch (error) {
    const message = formatCliError(error);
    console.error(`Error: ${message}`);
    console.error(usage());
    process.exit(1);
  }

  if (mode.kind === "version") {
    console.log(Cosm.version);
    process.exit(0);
  }

  // console.log("Cosm version:", Cosm.version);

  if (mode.kind === "help") {
    console.log(usage());
    process.exit(0);
  } else if (mode.kind === "repl") {
    if (mode.traceSend) {
      RuntimeDispatch.installTraceHooks({
        logSend: (line) => console.log(line),
      });
    }
    repl();
  } else if (mode.kind === "watch") {
    watchFileRunner(mode.filePath, mode);
  } else {
    const originalArgv = [...process.argv];
    try {
      const source = mode.kind === "eval"
        ? mode.source
        : (mode.kind === "test" ? "" : readFileSync(mode.filePath, "utf8"));
      if (mode.kind === "run" || (mode.kind === "test" && mode.filePath)) {
        process.argv = [originalArgv[0] ?? "bun", originalArgv[1] ?? "bin/cosm", mode.filePath, ...mode.scriptArgs];
      }
      if (mode.kind !== "test") {
        emitTraceFlags(source, mode);
      }
      if (mode.traceSend) {
        RuntimeDispatch.installTraceHooks({
          logSend: (line) => console.log(line),
        });
      }
      if (mode.kind === "test") {
        runTestMode(mode.filePath, mode.scriptArgs, mode);
      }
      const result = mode.vm ? Cosm.Interpreter.evalVm(source) : Cosm.Interpreter.eval(source);
      process.argv = originalArgv;
      // console.log(Cosm.Interpreter.inspect(result));
    } catch (e) {
      process.argv = originalArgv;
      console.error("Error:", formatCliError(e));
      process.exit(1);
    }
  }
}
