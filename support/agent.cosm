require("cosm/ai.cosm")
require("support/models.cosm")
require("support/prompts.cosm")
require("support/replies.cosm")

def appendTranscript(transcript, role, text)
  if transcript == "" then
    role + ": " + text
  else
    transcript + "\n" + role + ": " + text
  end
end

def replyForTranscript(transcript, latestText)
  let reply = ai.reply(prompts.replyPromptFromTranscript(transcript, latestText), models.AgentReply)
  models.AgentReply.validate(reply)
  reply
end

def streamReplyForTranscript(transcript, latestText)
  let text = ai.stream(prompts.streamPromptFromTranscript(transcript, latestText)) do |event|
    yield(event)
  end
  let reply = replies.text(text, "streamed")
  models.AgentReply.validate(reply)
  reply
end

def stepTranscript(transcript, latestText)
  let reply = replyForTranscript(transcript, latestText)
  let nextTranscript = appendTranscript(appendTranscript(transcript, "user", latestText), "assistant", reply.text)
  let step = { transcript: nextTranscript, reply: reply }
  models.ChatStep.validate(step)
  step
end

def streamStepTranscript(transcript, latestText)
  let reply = streamReplyForTranscript(transcript, latestText)
  let nextTranscript = appendTranscript(appendTranscript(transcript, "user", latestText), "assistant", reply.text)
  let step = { transcript: nextTranscript, reply: reply }
  models.ChatStep.validate(step)
  step
end

def transcriptFromConversation(conversation)
  Kernel.inspect(conversation.messages)
end

def handle(conversation, inbound)
  models.Conversation.validate(conversation)
  models.InboundMessage.validate(inbound)
  stepTranscript(transcriptFromConversation(conversation), inbound.text).reply
end

def fallback(conversation, inbound, errorMessage)
  models.Conversation.validate(conversation)
  models.InboundMessage.validate(inbound)
  replies.unavailable(errorMessage)
end

def exampleConversation()
  { key: "DDEMO:1710000000.000001", channel: "DDEMO", thread: "1710000000.000001", messages: [{ role: "user", user: "UDEMO", text: "How do I reset the notebook session?", ts: "1710000000.000001" }], sessionName: "slack-demo", sessionLength: 1 }
end

def exampleInbound()
  { channel: "DDEMO", thread: "1710000000.000001", user: "UDEMO", text: "How do I reset the notebook session?", ts: "1710000000.000001" }
end

def preview()
  prompts.replyPromptFromTranscript(transcriptFromConversation(exampleConversation()), exampleInbound().text)
end
