let models = require("support/models.cosm")

def text(text, rationale)
  let reply = { shouldReply: true, text: text, rationale: rationale, toolCalls: false, toolResults: false }
  models.AgentReply.validate(reply)
  reply
end

def unavailable(error_message)
  text("I hit a support-agent hiccup while handling that DM. Please try again in a bit.", error_message)
end
